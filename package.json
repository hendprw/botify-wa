{
  "name": "botify-wa",
  "version": "0.1.0",
  "description": "Botify — a lightweight WhatsApp bot framework with a plugin/command system and clean event API. The WhatsApp protocol core is vendored in-repo so the framework doesn't depend on a third-party package that could disappear.",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node examples/simple-bot.js",
    "dev": "node --watch examples/simple-bot.js"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-bot",
    "botify",
    "framework",
    "bot-framework",
    "multi-device"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^9.1.3",
    "async-mutex": "^0.5.0",
    "fflate": "^0.8.0",
    "fluent-ffmpeg": "^2.1.3",
    "libsignal": "git+https://github.com/whiskeysockets/libsignal-node",
    "lru-cache": "^11.1.0",
    "music-metadata": "^11.7.0",
    "p-queue": "^9.0.0",
    "pino": "^9.6",
    "protobufjs": "^7.2.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-rust-bridge": "0.5.2",
    "ws": "^8.13.0"
  },
  "peerDependencies": {
    "audio-decode": "^2.1.3",
    "jimp": "^1.6.0",
    "link-preview-js": "^3.0.0",
    "sharp": "^0.35.2"
  },
  "peerDependenciesMeta": {
    "audio-decode": {
      "optional": true
    },
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  }
}
